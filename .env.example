# ============================================================
# OpsSwarm — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── APPLICATION ────────────────────────────────────────────
APP_NAME=OpsSwarm
APP_ENV=development           # development | staging | production
APP_VERSION=0.1.0
APP_DEBUG=true
APP_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change-me-to-a-long-random-secret-key

# ─── API SERVER ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                 # Increase in production
API_RELOAD=true               # Set false in production

# ─── POSTGRESQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opsswarm
POSTGRES_USER=opsswarm_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
# Assembled by config.py — do not edit directly
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── REDIS ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                # Leave empty if no auth in dev
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ─── QDRANT ─────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=               # Required in production
QDRANT_COLLECTION_RUNBOOKS=runbooks
QDRANT_COLLECTION_INCIDENTS=historical_incidents
QDRANT_COLLECTION_RCA=rca_knowledge_base

# ─── LLM PROVIDERS ──────────────────────────────────────────
# Primary provider (groq | gemini | openrouter | ollama)
LLM_PROVIDER=groq

GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-70b-8192

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=anthropic/claude-3-sonnet

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── EMBEDDING MODEL ────────────────────────────────────────
EMBEDDING_PROVIDER=gemini     # gemini | openai | ollama
EMBEDDING_MODEL=models/embedding-001
EMBEDDING_DIMENSION=768

OPENAI_API_KEY=your-openai-api-key-here  # If using OpenAI embeddings

# ─── AWS ────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_ACCOUNT_ID=your-12-digit-account-id

# S3
S3_BUCKET_ARTIFACTS=opsswarm-artifacts-dev
S3_BUCKET_REPORTS=opsswarm-reports-dev

# DynamoDB
DYNAMODB_TABLE_WORKFLOW_STATE=opsswarm-workflow-state-dev
DYNAMODB_TABLE_AGENT_MEMORY=opsswarm-agent-memory-dev
DYNAMODB_TABLE_INCIDENT_LIFECYCLE=opsswarm-incident-lifecycle-dev

# SQS
SQS_QUEUE_ALERT_INGEST=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT/opsswarm-alert-ingest-dev.fifo
SQS_QUEUE_AGENT_TASKS=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT/opsswarm-agent-tasks-dev.fifo
SQS_QUEUE_APPROVAL_REQUESTS=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT/opsswarm-approval-requests-dev
SQS_QUEUE_REMEDIATION_RESULTS=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT/opsswarm-remediation-results-dev

# ─── LANGFUSE (Observability) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false        # Set true to enable LLM tracing

# ─── SAFETY & GUARDRAILS ────────────────────────────────────
# Risk score threshold (0-10) above which human approval is required
RISK_SCORE_APPROVAL_THRESHOLD=6
# Maximum actions the remediator can take autonomously per incident
MAX_AUTO_REMEDIATION_ACTIONS=3
# Timeout (seconds) waiting for human approval before escalation
HUMAN_APPROVAL_TIMEOUT_SECONDS=300

# ─── SIMULATION ─────────────────────────────────────────────
SIMULATION_DATA_PATH=./data
SIMULATION_SEED=42            # For reproducible data generation
SIMULATION_INCIDENTS_COUNT=5
